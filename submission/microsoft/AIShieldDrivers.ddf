.OPTION EXPLICIT
.Set CabinetNameTemplate=AIShieldDrivers-x64.cab
.Set DiskDirectoryTemplate=D:\AI_Shield\submission\microsoft
.Set CompressionType=MSZIP
.Set Cabinet=on
.Set Compress=on
.Set DestinationDir=wfp
